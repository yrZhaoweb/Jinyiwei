{
  "id": "jinyiwei",
  "name": "Jinyiwei",
  "version": "0.8.2",
  "description": "Governance, supervision, and markdown-controlled agent hierarchy for OpenClaw.",
  "skills": [
    "skills/jinyiwei-governance"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "bossTitle": {
        "type": "string",
        "description": "Title used to address the human operator",
        "default": "Boss"
      },
      "watchSelfTitle": {
        "type": "string",
        "description": "Self-referencing title for WatchAgent",
        "default": "WatchAgent"
      },
      "chatAgentName": {
        "type": "string",
        "description": "Display name for ChatAgent",
        "default": "ChatAgent"
      },
      "watchAgentName": {
        "type": "string",
        "description": "Display name for WatchAgent",
        "default": "WatchAgent"
      },
      "approvalMode": {
        "type": "string",
        "enum": [
          "strict",
          "graded",
          "hybrid"
        ],
        "description": "Approval workflow mode",
        "default": "hybrid"
      },
      "models": {
        "type": "object",
        "properties": {
          "chat": {
            "type": "string",
            "description": "LLM model for ChatAgent"
          },
          "watch": {
            "type": "string",
            "description": "LLM model for WatchAgent"
          },
          "groups": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "description": "LLM model per agent group"
          }
        }
      },
      "externalChannels": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Channels external agents can access",
        "default": [
          "feishu",
          "telegram"
        ]
      }
    }
  }
}
