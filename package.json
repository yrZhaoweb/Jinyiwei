{
  "name": "@yrzhao/jinyiwei",
  "version": "0.8.1",
  "type": "module",
  "description": "OpenClaw governance plugin and markdown charter pack.",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yrzhao/Jinyiwei.git"
  },
  "homepage": "https://github.com/yrzhao/Jinyiwei#readme",
  "bugs": {
    "url": "https://github.com/yrzhao/Jinyiwei/issues"
  },
  "keywords": [
    "openclaw",
    "governance",
    "agent",
    "plugin",
    "jinyiwei"
  ],
  "bin": {
    "jinyiwei": "./bin/jinyiwei.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "agents/",
    "manifests/",
    "openclaw-plugin.js",
    "openclaw.plugin.json",
    "jinyiwei.config.json",
    "rules/",
    "scripts/",
    "skills/",
    "skills_list.md",
    "templates/"
  ],
  "scripts": {
    "sync:skills": "node ./scripts/sync-skills-manifest.mjs",
    "sync:version": "node ./scripts/sync-version.mjs",
    "validate": "node ./scripts/validate-jinyiwei.mjs",
    "test": "node --test --test-concurrency=1 test/*.test.mjs",
    "prepublishOnly": "npm install && node ./scripts/sync-version.mjs && node ./scripts/sync-skills-manifest.mjs && node ./scripts/validate-jinyiwei.mjs"
  },
  "openclaw": {
    "extensions": [
      "./openclaw-plugin.js"
    ]
  }
}
